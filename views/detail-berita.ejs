<%- include('partials/header', { currentPage: 'berita' }) %>

<div style="display:grid; grid-template-columns:2fr 1fr; gap:40px; margin:30px 0;">

    <div>
        <div style="margin-bottom:12px;">
            <span class="badge" style="background:var(--primary); color:#fff;"><%= berita.kategori %></span>
        </div>
        <h1 style="font-size:2.2rem; color:var(--primary-dark);"><%= berita.judul %></h1>
        <div style="color:var(--text-light); margin:12px 0 20px;">
            <i class="far fa-calendar-alt"></i> <%= berita.tanggal %>
        </div>
        <img src="<%= berita.gambar %>" alt="<%= berita.judul %>" style="width:100%; border-radius:var(--radius); margin-bottom:24px;">
        <div style="font-size:1.1rem; line-height:1.9; color:#2d3d35;">
            <p><%= berita.isi %></p>
        </div>
        <div style="margin-top:24px; padding-top:20px; border-top:1px solid #e0ebe4;">
            <a href="/berita" class="btn-primary"><i class="fas fa-arrow-left"></i> Kembali ke Berita</a>
        </div>
    </div>

    <div>
        <h3 style="color:var(--primary-dark); border-bottom:3px solid var(--accent); padding-bottom:10px; margin-bottom:20px;">
            <i class="fas fa-clock"></i> Berita Lainnya
        </h3>
        <% beritaTerbaru.forEach(b => { %>
            <a href="/berita/<%= b.id %>" style="display:block; background:var(--white); border-radius:var(--radius); padding:16px; margin-bottom:12px; box-shadow:var(--shadow); transition:var(--transition);">
                <div style="display:flex; gap:12px;">
                    <img src="<%= b.gambar %>" alt="<%= b.judul %>" style="width:80px; height:80px; object-fit:cover; border-radius:8px;">
                    <div>
                        <h4 style="font-size:0.95rem; color:var(--primary-dark);"><%= b.judul %></h4>
                        <div style="font-size:0.8rem; color:var(--text-light);"><i class="far fa-calendar-alt"></i> <%= b.tanggal %></div>
                    </div>
                </div>
            </a>
        <% }) %>
    </div>

</div>

<%- include('partials/footer') %>