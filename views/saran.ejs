<%- include('partials/header', { currentPage: 'saran' }) %>

<div class="mini-hero">
    <h1><i class="fas fa-comment-dots"></i> Saran &amp; Kritik</h1>
    <p>Kami sangat menghargai masukan Anda untuk perbaikan pelayanan</p>
</div>

<div class="content-box">
    <% if (req.session && req.session.saranSuccess) { %>
        <div style="background:#d4edda; padding:16px 20px; border-radius:var(--radius); margin-bottom:20px; color:#155724; border-left:4px solid #28a745;">
            <i class="fas fa-check-circle"></i> <strong>Terima kasih!</strong> Saran/kritik Anda telah kami terima dan akan kami tindaklanjuti.
            <% req.session.saranSuccess = false; %>
        </div>
    <% } %>

    <form action="/saran" method="POST">
        <div class="form-group">
            <label for="saranNama"><i class="fas fa-user"></i> Nama Lengkap</label>
            <input type="text" id="saranNama" name="nama" placeholder="Masukkan nama Anda" required>
        </div>
        <div class="form-group">
            <label for="saranEmail"><i class="fas fa-envelope"></i> Email</label>
            <input type="email" id="saranEmail" name="email" placeholder="Masukkan email Anda" required>
        </div>
        <div class="form-group">
            <label for="saranKategori"><i class="fas fa-tag"></i> Kategori</label>
            <select id="saranKategori" name="kategori">
                <option value="Saran">Saran</option>
                <option value="Kritik">Kritik</option>
                <option value="Pertanyaan">Pertanyaan</option>
                <option value="Pengaduan">Pengaduan</option>
            </select>
        </div>
        <div class="form-group">
            <label for="saranPesan"><i class="fas fa-comment"></i> Pesan</label>
            <textarea id="saranPesan" name="pesan" rows="5" placeholder="Tulis saran, kritik, atau pertanyaan Anda..." required></textarea>
        </div>
        <button type="submit" class="btn-primary"><i class="fas fa-paper-plane"></i> Kirim</button>
    </form>
</div>

<%- include('partials/footer') %>