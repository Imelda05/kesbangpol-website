<%- include('partials/header', { currentPage: 'layanan' }) %>
<div class="container">
  <div class="mini-hero">
    <h1><i class="fas fa-concierge-bell"></i> Layanan</h1>
    <p>Informasi layanan publik yang disediakan oleh Kesbangpol</p>
  </div>

  <div class="card-grid">
    <% layanan.forEach(l => { %>
      <div class="card">
        <div class="card-body" style="text-align:center;">
          <i class="fas <%= l.icon %>" style="font-size:3rem; color:var(--primary); margin-bottom:12px;"></i>
          <h4><%= l.judul %></h4>
          <p><%= l.deskripsi %></p>
          <a href="/kontak" class="btn-link">Hubungi Kami <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<%- include('partials/footer') %>