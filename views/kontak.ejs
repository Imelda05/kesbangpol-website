<%- include('partials/header', { currentPage: 'kontak' }) %>
<div class="container">
  <div class="mini-hero">
    <h1><i class="fas fa-address-book"></i> Kontak Kami</h1>
    <p>Hubungi kami untuk informasi lebih lanjut</p>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px;">

    <!-- Informasi Kontak -->
    <div>
      <div class="content-box">
        <h2><i class="fas fa-info-circle"></i> Informasi Kontak</h2>
        <p><i class="fas fa-map-marker-alt" style="width:24px; color:var(--primary);"></i> <strong>Alamat:</strong> <%= kontak.alamat %></p>
        <p><i class="fas fa-phone" style="width:24px; color:var(--primary);"></i> <strong>Telepon:</strong> <%= kontak.telepon %></p>
        <p><i class="fas fa-fax" style="width:24px; color:var(--primary);"></i> <strong>Fax:</strong> <%= kontak.fax %></p>
        <p><i class="fas fa-envelope" style="width:24px; color:var(--primary);"></i> <strong>Email:</strong> <%= kontak.email %></p>
        <p><i class="fab fa-whatsapp" style="width:24px; color:var(--primary);"></i> <strong>WhatsApp:</strong> <%= kontak.whatsapp %></p>
        <p style="margin-top:12px; padding:12px; background:var(--secondary); border-radius:var(--radius);">
          <i class="fas fa-clock" style="color:var(--primary);"></i> <strong>Jam Layanan:</strong><br>
          <%= kontak.jamLayanan %>
        </p>
      </div>
    </div>

    <!-- Peta -->
    <div>
      <div class="content-box">
        <h2><i class="fas fa-map"></i> Peta Lokasi</h2>
        <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:var(--radius);">
          <iframe src="<%= kontak.maps %>" style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;" allowfullscreen></iframe>
        </div>
      </div>
    </div>

  </div>
</div>
<%- include('partials/footer') %>