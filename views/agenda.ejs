<%- include('partials/header', { currentPage: 'agenda' }) %>

<div class="mini-hero">
    <h1><i class="fas fa-calendar-alt"></i> Agenda</h1>
    <p>Jadwal kegiatan dan agenda pimpinan Kesbangpol</p>
</div>

<div class="card-grid">
    <% agenda.forEach(a => { %>
        <div class="card">
            <div class="card-body">
                <div style="font-size:3rem; text-align:center; margin-bottom:8px;"><%= a.icon %></div>
                <h4><%= a.judul %></h4>
                <div class="meta"><i class="far fa-calendar-alt"></i> <%= a.tanggal %> • <%= a.waktu %></div>
                <p><i class="fas fa-map-marker-alt"></i> <%= a.tempat %></p>
            </div>
        </div>
    <% }) %>
</div>

<%- include('partials/footer') %>