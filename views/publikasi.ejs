<%- include('partials/header', { currentPage: 'publikasi' }) %>
<div class="container">
  <div class="mini-hero"><h1>📰 Publikasi / Berita</h1><p>Informasi terbaru seputar Kesbangpol</p></div>
  <div class="card-grid">
    <% berita.forEach(b => { %>
      <div class="card">
        <div class="card-img" style="background-image:url('<%= b.gambar %>');"></div>
        <div class="card-body">
          <h4><%= b.judul %></h4>
          <div class="meta">📅 <%= b.tanggal %></div>
          <p><%= b.ringkasan %></p>
          <a href="/detail-berita?id=<%= b.id %>" class="btn-link">Baca selengkapnya →</a>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<%- include('partials/footer') %>