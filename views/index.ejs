            ],
            foto: [
                { id: 1, judul: 'Pembukaan Rakor Pemilu', gambar: 'https://picsum.photos/seed/foto1/600/400' },
                { id: 2, judul: 'Sosialisasi Wawasan Kebangsaan', gambar: 'https://picsum.photos/seed/foto2/600/400' },
                { id: 3, judul: 'Kunjungan Kerja ke Banyuasin', gambar: 'https://picsum.photos/seed/foto3/600/400' },
                { id: 4, judul: 'Pelatihan Fasilitator Desa', gambar: 'https://picsum.photos/seed/foto4/600/400' },
                { id: 5, judul: 'Dialog Kebangsaan dengan Pemuda', gambar: 'https://picsum.photos/seed/foto5/600/400' },
                { id: 6, judul: 'Penandatanganan MoU', gambar: 'https://picsum.photos/seed/foto6/600/400' }
            ],
            video: [
                { id: 1, judul: 'Profil Kesbangpol 2026', embed: 'https://www.youtube.com/embed/dQw4w9WgXcQ' },
                { id: 2, judul: 'Rakor Pemilu Damai', embed: 'https://www.youtube.com/embed/dQw4w9WgXcQ' },
                { id: 3, judul: 'Sosialisasi Bela Negara', embed: 'https://www.youtube.com/embed/dQw4w9WgXcQ' },
                { id: 4, judul: 'Dialog Kebangsaan', embed: 'https://www.youtube.com/embed/dQw4w9WgXcQ' }
            ],
            dokumen: [
                { id: 1, judul: 'Peraturan Daerah tentang Kesbangpol', jenis: 'Perda', tahun: '2025',
                ukuran: '2.4 MB' },
                { id: 2, judul: 'Rencana Strategis 2026-2030', jenis: 'Renstra', tahun: '2026',
                ukuran: '3.1 MB' },
                { id: 3, judul: 'Panduan Moderasi Beragama', jenis: 'Buku Saku', tahun: '2025',
                ukuran: '1.8 MB' },
                { id: 4, judul: 'Laporan Kinerja 2025', jenis: 'Laporan', tahun: '2025',
                ukuran: '4.2 MB' },
                { id: 5, judul: 'Profil Kesbangpol 2026', jenis: 'Profil', tahun: '2026',
                ukuran: '5.6 MB' },
                { id: 6, judul: 'Pedoman Desa Damai', jenis: 'Pedoman', tahun: '2025',
                ukuran: '2.0 MB' }
            ]
        };

        // ============================================================
        // RENDER FUNGSI
        // ============================================================
        function renderBerita(containerId, list, limit) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const items = limit ? list.slice(0, limit) : list;
            container.innerHTML = items.map(b => `
                    <div class="card">
                        <div class="card-img" style="background-image:url('${b.gambar}');"></div>
                        <div class="card-body">
                            <span class="badge">${b.kategori}</span>
                            <h4>${b.judul}</h4>
                            <div class="meta"><i class="far fa-calendar-alt"></i> ${b.tanggal}</div>
                            <p>${b.ringkasan}</p>
                            <span class="btn-link" onclick="showDetail(${b.id})">Baca selengkapnya <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </div>
                `).join('');
        }

        function renderAgenda(containerId, list, limit) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const items = limit ? list.slice(0, limit) : list;
            container.innerHTML = items.map(a => `
                    <div class="item">
                        <div class="icon">${a.icon}</div>
                        <h5>${a.judul}</h5>
                        <div class="date"><i class="far fa-calendar-alt"></i> ${a.tanggal} • ${a.waktu}</div>
                        <div style="font-size:0.85rem; color:var(--primary-light);"><i class="fas fa-map-marker-alt"></i> ${a.tempat}</div>
                    </div>
                `).join('');
        }

        function renderFoto(containerId, list, limit) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const items = limit ? list.slice(0, limit) : list;
            container.innerHTML = items.map(f => `
                    <div class="item">
                        <div class="thumb" style="background-image:url('${f.gambar}');"></div>
                        <h5>${f.judul}</h5>
                    </div>
                `).join('');
        }

        function renderDokumen() {
            const tbody = document.getElementById('dokumenTable');
            if (!tbody) return;
            tbody.innerHTML = data.dokumen.map((d, i) => `
                    <tr>
                        <td>${i + 1}</td>
                        <td>${d.judul}</td>
                        <td>${d.jenis}</td>
                        <td>${d.tahun}</td>
                        <td><a href="#" style="color:var(--primary);font-weight:600;" onclick="alert('Unduh: ${d.judul}'); return false;"><i class="fas fa-download"></i> Unduh</a></td>
                    </tr>
                `).join('');
        }

        function renderVideo() {
            const container = document.getElementById('videoContainer');
            if (!container) return;
            container.innerHTML = data.video.map(v => `
                    <div class="item" style="padding:0; overflow:hidden;">
                        <div style="position:relative; padding-bottom:56.25%; height:0; background:#000;">
                            <iframe src="${v.embed}" style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;" allowfullscreen></iframe>
                        </div>
                        <div style="padding:12px 16px 16px;">
                            <h5>${v.judul}</h5>
                        </div>
                    </div>
                `).join('');
        }

        function renderAgendaAll() {
            const container = document.getElementById('agendaAllContainer');
            if (!container) return;
            container.innerHTML = data.agenda.map(a => `
                    <div class="card">
                        <div class="card-body">
                            <div style="font-size:3rem; text-align:center;">${a.icon}</div>
                            <h4>${a.judul}</h4>
                            <div class="meta"><i class="far fa-calendar-alt"></i> ${a.tanggal} • ${a.waktu}</div>
                            <p><i class="fas fa-map-marker-alt"></i> ${a.tempat}</p>
                        </div>
                    </div>
                `).join('');
        }

        function renderBeritaAll() {
            const container = document.getElementById('beritaAllContainer');
            if (!container) return;
            container.innerHTML = data.berita.map(b => `
                    <div class="card">
                        <div class="card-img" style="background-image:url('${b.gambar}');"></div>
                        <div class="card-body">
                            <span class="badge">${b.kategori}</span>
                            <h4>${b.judul}</h4>
                            <div class="meta"><i class="far fa-calendar-alt"></i> ${b.tanggal}</div>
                            <p>${b.ringkasan}</p>
                            <span class="btn-link" onclick="showDetail(${b.id})">Baca selengkapnya <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </div>
                `).join('');
        }

        function renderGaleri() {
            const container = document.getElementById('galeriContainer');
            if (!container) return;
            container.innerHTML = data.foto.map(f => `
                    <div class="item">
                        <div class="thumb" style="background-image:url('${f.gambar}');"></div>
                        <h5>${f.judul}</h5>
                    </div>
                `).join('');
        }

        // ============================================================
        // NAVIGASI
        // ============================================================
        function navigateTo(page, sub) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            const target = document.getElementById('page-' + page);
            if (target) target.classList.add('active');

            document.querySelectorAll('.nav-menu a').forEach(a => a.classList.remove('active'));
            document.querySelectorAll(`.nav-menu a[data-page="${page}"]`).forEach(a => a.classList.add('active'));

            if (page === 'profil' && sub) {
                setTimeout(() => {
                    const el = document.getElementById('sub-' + sub);
                    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 100);
            }

            document.getElementById('navMenu').classList.remove('open');
            document.querySelectorAll('.dropdown.open').forEach(d => d.classList.remove('open'));
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showDetail(id) {
            const berita = data.berita.find(b => b.id === id);
            if (!berita) return;
            alert(`📰 ${berita.judul}\n\n📅 ${berita.tanggal}\n🏷️ ${berita.kategori}\n\n${berita.isi}`);
        }

        // ============================================================
        // SLIDER
        // ============================================================
        let slideIndex = 0;
        const slides = document.querySelectorAll('.hero-slider .slide');
        const dots = document.querySelectorAll('#sliderDots span');

        function showSlide(index) {
            slides.forEach((s, i) => s.classList.toggle('active', i === index));
            dots.forEach((d, i) => d.classList.toggle('active', i === index));
            slideIndex = index;
        }

        document.getElementById('sliderNext')?.addEventListener('click', () => {
            showSlide((slideIndex + 1) % slides.length);
        });
        document.getElementById('sliderPrev')?.addEventListener('click', () => {
            showSlide((slideIndex - 1 + slides.length) % slides.length);
        });
        dots.forEach((d, i) => d.addEventListener('click', () => showSlide(i)));

        let slideInterval = setInterval(() => {
            showSlide((slideIndex + 1) % slides.length);
        }, 5000);
        document.querySelector('.hero-slider')?.addEventListener('mouseenter', () => clearInterval(slideInterval));
        document.querySelector('.hero-slider')?.addEventListener('mouseleave', () => {
            slideInterval = setInterval(() => {
                showSlide((slideIndex + 1) % slides.length);
            }, 5000);
        });

        // ============================================================
        // SAMBUTAN READ MORE
        // ============================================================
        const sambutanText = document.getElementById('sambutanText');
        const sambutanToggle = document.getElementById('sambutanToggle');
        if (sambutanToggle && sambutanText) {
            sambutanToggle.addEventListener('click', () => {
                const expanded = sambutanText.classList.toggle('expanded');
                sambutanToggle.innerHTML = expanded ?
                    'Sembunyikan <i class="fas fa-chevron-up"></i>' :
                    'Baca selengkapnya <i class="fas fa-chevron-down"></i>';
            });
        }

        // ============================================================
        // MOBILE MENU
        // ============================================================
        const menuToggle = document.getElementById('menuToggle');
        const navMenu = document.getElementById('navMenu');
        const dropdownProfil = document.getElementById('dropdownProfil');
        const dropdownDokumentasi = document.getElementById('dropdownDokumentasi');

        if (menuToggle && navMenu) {
            menuToggle.addEventListener('click', function(e) {
                e.stopPropagation();
                navMenu.classList.toggle('open');
            });
        }

        // Dropdown mobile toggle
        if (dropdownProfil) {
            const link = dropdownProfil.querySelector('a[data-page="profil"]');
            if (link) {
                link.addEventListener('click', function(e) {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        dropdownProfil.classList.toggle('open');
                    } else {
                        navigateTo('profil');
                    }
                });
            }
        }

        if (dropdownDokumentasi) {
            const link = dropdownDokumentasi.querySelector('a[data-page="dokumentasi"]');
            if (link) {
                link.addEventListener('click', function(e) {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        dropdownDokumentasi.classList.toggle('open');
                    }
                });
            }
        }

        document.addEventListener('click', function(e) {
            if (!e.target.closest('.navbar')) {
                navMenu.classList.remove('open');
            }
        });

        // ============================================================
        // FORM SARAN
        // ============================================================
        document.getElementById('formSaran')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const nama = document.getElementById('saranNama').value.trim();
            const email = document.getElementById('saranEmail').value.trim();
            const pesan = document.getElementById('saranPesan').value.trim();

            if (!nama || !email || !pesan) {
                document.getElementById('saranFeedback').textContent = '⚠️ Semua field harus diisi!';
                document.getElementById('saranFeedback').style.color = '#c0392b';
                return;
            }

            document.getElementById('saranFeedback').textContent = '✅ Terima kasih! Saran/kritik Anda telah kami terima.';
            document.getElementById('saranFeedback').style.color = 'var(--primary)';
            this.reset();

            setTimeout(() => {
                document.getElementById('saranFeedback').textContent = '';
            }, 5000);
        });

        // ============================================================
        // NAVIGASI DARI MENU
        // ============================================================
        document.querySelectorAll('.nav-menu a[data-page]').forEach(a => {
            a.addEventListener('click', function(e) {
                const page = this.dataset.page;
                const sub = this.dataset.sub || null;
                if (window.innerWidth <= 768) {
                    const parent = this.closest('.dropdown');
                    if (parent && parent.querySelector('.dropdown-content')) {
                        return;
                    }
                }
                navigateTo(page, sub);
            });
        });

        // ============================================================
        // INIT
        // ============================================================
        renderBerita('beritaContainer', data.berita, 3);
        renderBeritaAll();
        renderAgenda('agendaContainer', data.agenda, 4);
        renderAgendaAll();
        renderFoto('fotoContainer', data.foto, 4);
        renderGaleri();
        renderDokumen();
        renderVideo();

        console.log('✅ Website Kesbangpol siap digunakan!');
    </script>

</body>
</html>